  m_Script: {fileID: 11500000, guid: d1072b91930ee074f987e18df24e394c, type: 3}
  m_Name: Burpee
  m_EditorClassIdentifier: Assembly-CSharp::PainQuest.DialogueSequence
  lines:
  - text: Fantastic job! You pushed through the burpee exercise with determination.
    audioClip: {fileID: 8300000, guid: 2e4ab4f60db876a4083c0761c7bd95ea, type: 3}
    displayDuration: 6
  - text: Your commitment to completing difficult exercises is a sign of real progress.
    audioClip: {fileID: 8300000, guid: 88c1d3c7eeb84af44a02d6716eeb114a, type: 3}
    displayDuration: 5
  - text: Get ready for the next challenge ahead.
    audioClip: {fileID: 8300000, guid: a677990110e9da34ba6a2944a5c810ad, type: 3}
    displayDuration: 3
