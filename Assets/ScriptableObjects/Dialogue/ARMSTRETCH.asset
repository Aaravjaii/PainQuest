  m_Name: ARMSTRETCH
  m_EditorClassIdentifier: Assembly-CSharp::PainQuest.DialogueSequence
  lines:
  - text: Great job! You've finished your arm stretch session
    audioClip: {fileID: 8300000, guid: d283fe3846c255d469fbf6541746fe20, type: 3}
    displayDuration: 4
  - text: Remember to maintain steady breathing and avoid sudden movements while
      stretching
    audioClip: {fileID: 8300000, guid: 8e98e2b2be769d74c9cbdf7f66e01351, type: 3}
    displayDuration: 6
  - text: Let's prepare for the next exercise
    audioClip: {fileID: 8300000, guid: 55b45f48c4448a54abfb69adb74d63aa, type: 3}
    displayDuration: 3
