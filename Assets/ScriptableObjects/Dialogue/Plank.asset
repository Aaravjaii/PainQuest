  m_EditorClassIdentifier: Assembly-CSharp::PainQuest.DialogueSequence
  lines:
  - text: Fantastic work! You've completed the final exercise of the Core Strength
      Quest.
    audioClip: {fileID: 8300000, guid: e1b68c52cd602b94f8cc33950ca884e4, type: 3}
    displayDuration: 5
  - text: A strong core helps improve balance, posture, and overall stability.
    audioClip: {fileID: 8300000, guid: 85c66eb2fe329534eaaef194d107308b, type: 3}
    displayDuration: 5
  - text: Quest Complete. Take a moment to rest and celebrate your achievement!
    audioClip: {fileID: 8300000, guid: 15b64a2045c303d4daa90451ba617f16, type: 3}
    displayDuration: 4
