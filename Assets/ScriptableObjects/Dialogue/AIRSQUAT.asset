  m_Script: {fileID: 11500000, guid: d1072b91930ee074f987e18df24e394c, type: 3}
  m_Name: AIRSQUAT
  m_EditorClassIdentifier: Assembly-CSharp::PainQuest.DialogueSequence
  lines:
  - text: Excellent work! You've powered through the air squat exercise.
    audioClip: {fileID: 8300000, guid: 8b3d5e6f8fc06314ca5becdd2a02fc69, type: 3}
    displayDuration: 4
  - text: Every squat you complete helps improve strength, endurance, and movement
      confidence
    audioClip: {fileID: 8300000, guid: 8f629b9c82857664f958f6118a6bc469, type: 3}
    displayDuration: 5
  - text: Take a deep breath, recover, and prepare yourself for the next exercise.
    audioClip: {fileID: 8300000, guid: 74db2760bc53204488a0b554a03db95d, type: 3}
    displayDuration: 5
