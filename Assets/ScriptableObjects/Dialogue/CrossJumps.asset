  m_Script: {fileID: 11500000, guid: d1072b91930ee074f987e18df24e394c, type: 3}
  m_Name: CrossJumps
  m_EditorClassIdentifier: Assembly-CSharp::PainQuest.DialogueSequence
  lines:
  - text: Great job completing the cross jumps exercise!
    audioClip: {fileID: 8300000, guid: 61eebc383f05b9e4887a04d179544629, type: 3}
    displayDuration: 3
  - text: Regular practice can enhance cardiovascular health and support better overall
      mobility.
    audioClip: {fileID: 8300000, guid: 5721ba8abafcc1f429f3e0210098bcb0, type: 3}
    displayDuration: 3
  - text: Catch your breath, relax for a moment, and let's continue your journey
      forward.
    audioClip: {fileID: 8300000, guid: ef23ac9e97814ca48a2e92b30c2e74ef, type: 3}
    displayDuration: 7
